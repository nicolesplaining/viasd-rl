\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Method overview --- the learned \textbf  {gate} is the core. For each drafted token it reads $q$-free features $s_t$ and routes to \textsc  {accept} (drafter), \textsc  {regenerate} (slim $q'$), or \textsc  {escalate} (full $q$). \textbf  {RL slots in only at training time} (dashed): each action's outcome yields a reward $r_t=\text  {match}_t-\lambda \,\text  {cost}_t$ (with $q$ consulted off-line), and a policy-gradient step updates the gate parameters $\theta $. At inference the dashed path is removed and the gate runs from $q$-free features alone.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:flow}{{1}{2}{Method overview --- the learned \textbf {gate} is the core. For each drafted token it reads $q$-free features $s_t$ and routes to \textsc {accept} (drafter), \textsc {regenerate} (slim $q'$), or \textsc {escalate} (full $q$). \textbf {RL slots in only at training time} (dashed): each action's outcome yields a reward $r_t=\text {match}_t-\lambda \,\text {cost}_t$ (with $q$ consulted off-line), and a policy-gradient step updates the gate parameters $\theta $. At inference the dashed path is removed and the gate runs from $q$-free features alone}{figure.1}{}}
